{
  "_comment": "sori monorepo - AI agent enforcement settings. Complete replacement for .claude/settings.json. Deny rules override allow rules (first match wins in deny->ask->allow order).",
  "_deny_map": {
    "S-01": "Read .env files blocked (previously only Bash cat was blocked)",
    "S-02": "Read secrets/, key, pem files blocked",
    "I-02": "IaC/deploy directory write-protected via Edit and Write tools",
    "I-03": "CI pipeline (.github/workflows/) write-protected",
    "I-04": "Claude settings (.claude/) write-protected from self-modification",
    "B-01": "prod direct push blocked",
    "B-02": "stg direct push blocked",
    "B-03": "force push blocked (all variants)",
    "B-04": "--no-verify pre-commit bypass blocked"
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(poetry:*)",
      "Bash(conda:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(pre-commit:*)",
      "Bash(celery:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(make:*)",
      "Bash(./start_dev.sh:*)",
      "Bash(./start_staging.sh:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(./start_prod.sh:*)",
      "Bash(git push origin prod:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin stg:*)",
      "Bash(git push origin staging:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f :*)",
      "Bash(*--force-with-lease*:*)",
      "Bash(*--no-verify*:*)",
      "Bash(rm -rf /:*)",
      "Bash(*prod*database*:*)",
      "Bash(echo *MONGODB_URL*:*)",
      "Bash(echo *AWS_SECRET*:*)",
      "Bash(echo *JWT_SECRET*:*)",
      "Bash(echo *SECRET*:*)",
      "Bash(echo *PASSWORD*:*)",
      "Bash(echo *TOKEN*:*)",
      "Bash(cat *.env*:*)",
      "Bash(cat *secrets/*:*)",
      "Bash(head *.env*:*)",
      "Bash(tail *.env*:*)",
      "Bash(less *.env*:*)",
      "Bash(more *.env*:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform import:*)",
      "Bash(aws * --profile prod*:*)",
      "Bash(gcloud *:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(docker push:*)",
      "Bash(gh workflow run:*)",
      "Read(./.env*)",
      "Read(.env*)",
      "Read(./secrets/**)",
      "Read(secrets/**)",
      "Read(./*.pem)",
      "Read(*.pem)",
      "Read(./*.key)",
      "Read(*.key)",
      "Read(./*.p12)",
      "Read(./*.pfx)",
      "Edit(./.github/workflows/**)",
      "Edit(.github/workflows/**)",
      "Write(./.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(./.github/actions/**)",
      "Edit(.github/actions/**)",
      "Write(./.github/actions/**)",
      "Write(.github/actions/**)",
      "Edit(./deploy/**)",
      "Edit(deploy/**)",
      "Write(./deploy/**)",
      "Write(deploy/**)",
      "Edit(./.claude/**)",
      "Edit(.claude/**)",
      "Write(./.claude/**)",
      "Write(.claude/**)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "secrets/",
        "*.pem",
        "*.key",
        "*.p12",
        "*.pfx",
        "id_rsa",
        "id_ecdsa",
        "id_ed25519"
      ],
      "denyWrite": [
        ".github/",
        "deploy/",
        ".claude/",
        "CLAUDE.md",
        "AGENTS.md",
        "terraform/",
        "*.tf",
        "*.tfvars"
      ]
    },
    "network": {
      "allowedDomains": [
        "pypi.org",
        "files.pythonhosted.org",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "hub.docker.com",
        "registry-1.docker.io",
        "auth.docker.io",
        "conda.anaconda.org",
        "repo.anaconda.com",
        "storage.googleapis.com",
        "dl-cdn.alpinelinux.org",
        "deb.debian.org",
        "archive.ubuntu.com",
        "crates.io",
        "proxy.golang.org"
      ]
    }
  }
}
